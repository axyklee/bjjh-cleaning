# Environment variables for development (copy to .env and modify as needed)

# Secret used for authentication (set in production)
AUTH_SECRET=development-secret-shhh

# Trust host header (true/false)
AUTH_TRUST_HOST=true

# Google OAuth credentials
AUTH_GOOGLE_CLIENT_ID=<obtain from Google Cloud Console>
AUTH_GOOGLE_CLIENT_SECRET=<obtain from Google Cloud Console>

AUTH_URL="http://localhost:3000"

# Database connection URL
DATABASE_URL=postgres://postgres:postgres@localhost:9221/postgres

# MinIO configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9222
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=bucket
MINIO_USE_SSL=false

# Node environment: development, test, or production
NODE_ENV=development
